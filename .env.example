# Firebase Configuration - 100% FREE TIER
# Get these from: https://console.firebase.google.com/project/{projectId}/settings/general
# Spark Plan (Free): Unlimited users, 50K daily read/write/delete, 5GB Storage, HTTPS included

VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_ADMIN_CREATION_PASSWORD=choose_a_strong_admin_creation_password

# Copy your actual values from Firebase Console > Project Settings > General
# DO NOT commit .env.local to git (it's in .gitignore)
